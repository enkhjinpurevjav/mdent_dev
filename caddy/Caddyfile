{
  email youremail@domain.com
}

# Main web app (frontend) + API + media
mdent.cloud, www.mdent.cloud, app.mdent.cloud {
  encode gzip

  route {
    # API must be handled BEFORE frontend fallback
    @api path /api/*
    handle @api {
      reverse_proxy mdent-cloud-backend-1:8080
    }

    # Media must be handled
    @media path /media/*
    handle @media {
      reverse_proxy mdent-cloud-backend-1:8080
    }

    # Fallback: everything else to frontend
    handle {
      reverse_proxy frontend:3000
    }
  }
}

# Booking / doctor UI
book.mdent.cloud {
  encode gzip
  reverse_proxy frontend:3000
}

# Public API (direct API subdomain)
api.mdent.cloud {
  encode gzip

  @cors_preflight {
    method OPTIONS
    path /api/*
  }

  handle @cors_preflight {
    header {
      Access-Control-Allow-Origin https://mdent.cloud
      Access-Control-Allow-Methods GET,POST,PUT,PATCH,DELETE,OPTIONS
      Access-Control-Allow-Headers Authorization,Content-Type
      Access-Control-Allow-Credentials true
      Access-Control-Max-Age 86400
    }
    respond "" 204
  }

  handle {
    reverse_proxy mdent-cloud-backend-1:8080

    header {
      Access-Control-Allow-Origin https://mdent.cloud
      Access-Control-Allow-Methods GET,POST,PUT,PATCH,DELETE,OPTIONS
      Access-Control-Allow-Headers Authorization,Content-Type
      Access-Control-Allow-Credentials true
      Access-Control-Max-Age 86400
    }
  }
}
